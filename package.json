{
  "name": "@ternetin/opencode-codex-multiplexer",
  "version": "0.1.0",
  "description": "OpenCode TUI plugin for Codex auth profile switching and usage windows.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "codex",
    "openai",
    "tui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./src/tui.tsx"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.4",
    "@opentui/core": "^0.2.11",
    "@opentui/solid": "^0.2.11",
    "solid-js": "1.9.12"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.15.4",
    "@opentui/core": ">=0.2.11",
    "@opentui/solid": ">=0.2.11",
    "solid-js": "1.9.12"
  }
}
